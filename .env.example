DATABASE_URL=file:./prisma/dev.db
NEXT_PRIVATE_DISABLE_DEVTOOLS=1

# Zoho Catalyst QuickML LLM Serving Integration
# Use GLM-4.7-Flash or Qwen 3.6 - 35B Vision Language from your Catalyst project
QUICKML_CHAT_URL=
NEXT_PUBLIC_QUICKML_CHAT_URL=
QUICKML_MODEL=GLM-4.7-Flash

# Palantir Foundry Integration
FOUNDRY_BASE_URL=
FOUNDRY_API_TOKEN=
FOUNDRY_FIR_OBJECT_TYPE=FirCase
FOUNDRY_OAUTH_CLIENT_ID=
FOUNDRY_OAUTH_CLIENT_SECRET=
FOUNDRY_ONTOLOGY_API_NAME=
